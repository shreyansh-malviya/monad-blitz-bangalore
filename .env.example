# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/monadblitz

# Redis
REDIS_URL=redis://localhost:6379

# Monad Testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143
EXPLORER_URL=https://testnet.monadexplorer.com

# Contract Addresses (fill after: forge script script/Deploy.s.sol --broadcast)
AGENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
QUERY_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
REPUTATION_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
DECISION_LEDGER_ADDRESS=0x0000000000000000000000000000000000000000
STAKE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
PROPOSAL_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# Deployer Wallet
DEPLOYER_PRIVATE_KEY=0x

# Agent Wallets (testnet only - generate via scripts/generate_wallets.py)
ALPHA_PRIVATE_KEY=0x
BETA_PRIVATE_KEY=0x
GAMMA_PRIVATE_KEY=0x

# Test User Wallets
TEST_USER_PRIVATE_KEY=0x

# Service Ports
ORCHESTRATOR_PORT=8000
ALPHA_PORT=8001
BETA_PORT=8002
GAMMA_PORT=8003

# Orchestrator Settings
ESCALATION_THRESHOLD=0.75
MAX_ROUNDS=3
ROUND_TIMEOUT_SECONDS=90
MIN_STAKE_MON=10000000000000000

# Proposal Track Settings
PROPOSAL_BIDDING_TIMEOUT=25
PROPOSAL_DISCUSSION_TIMEOUT=60
PROPOSAL_MAX_ROLES=6
PROPOSAL_DISCUSSION_ROUNDS=3

# IPFS / Pinata (optional — offline stub used if keys are missing)
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# Multi-node / P2P Settings
# NODE_MODE: "local" (single machine) | "network" (multi-machine WiFi)
NODE_MODE=local
# Your publicly reachable endpoint when running in network mode
NODE_ENDPOINT=
# Comma-separated bootstrap peer endpoints (blank = mDNS auto-discovery on LAN)
BOOTSTRAP_NODES=
MDNS_ENABLED=true

# JWT
JWT_SECRET=change-me-in-production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CHAIN_ID=10143
NEXT_PUBLIC_EXPLORER_URL=https://testnet.monadexplorer.com
